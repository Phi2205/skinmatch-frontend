// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String
  phone     String?
  address   String?
  city      String?
  country   String?
  zipCode   String?
  
  // Skin profile
  skinType  String?    // normal, oily, dry, combination, sensitive
  concerns  String[]   // array of concerns: acne, wrinkles, dryness, oiliness, sensitivity, pigmentation
  
  role      String     @default("USER") // USER or ADMIN
  
  orders    Order[]
  cartItems CartItem[]
  reviews   Review[]
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  description String?
  
  products  Product[]
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model SkinType {
  id        String     @id @default(cuid())
  name      String     @unique
  
  products  Product[]
  
  createdAt DateTime   @default(now())
}

model Concern {
  id        String     @id @default(cuid())
  name      String     @unique
  
  products  Product[]
  
  createdAt DateTime   @default(now())
}

model Ingredient {
  id        String     @id @default(cuid())
  name      String     @unique
  description String?
  
  products  Product[]
  
  createdAt DateTime   @default(now())
}

model Product {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  description String?
  longDescription String?
  
  price     Float
  compareAtPrice Float?
  
  category  Category   @relation(fields: [categoryId], references: [id])
  categoryId String
  
  skinTypes SkinType[]
  concerns   Concern[]
  ingredients Ingredient[]
  
  imageUrl  String?
  images    String[]   // array of image URLs
  
  stock     Int        @default(0)
  
  // SEO
  metaTitle String?
  metaDescription String?
  
  // Product details
  size      String?    // e.g., "50ml", "100ml"
  scent     String?
  
  // Ratings
  averageRating Float @default(0)
  totalReviews Int @default(0)
  
  orderItems OrderItem[]
  cartItems  CartItem[]
  reviews    Review[]
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  @@index([categoryId])
  @@index([slug])
}

model Cart {
  id        String     @id @default(cuid())
  items     CartItem[]
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String     @id @default(cuid())
  
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  
  product   Product    @relation(fields: [productId], references: [id])
  productId String
  
  quantity  Int        @default(1)
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Order {
  id        String     @id @default(cuid())
  
  user      User       @relation(fields: [userId], references: [id])
  userId    String
  
  items     OrderItem[]
  
  // Shipping
  shippingName String
  shippingEmail String
  shippingPhone String
  shippingAddress String
  shippingCity String
  shippingCountry String
  shippingZipCode String
  
  // Pricing
  subtotal  Float
  shippingCost Float @default(0)
  tax       Float @default(0)
  total     Float
  
  // Status
  status    String     @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  paymentStatus String @default("UNPAID") // UNPAID, PAID, REFUNDED
  paymentMethod String? // STRIPE, PAYPAL, BANK_TRANSFER
  
  notes     String?
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String     @id @default(cuid())
  
  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  
  product   Product    @relation(fields: [productId], references: [id])
  productId String
  
  quantity  Int
  price     Float      // price at time of purchase
  
  createdAt DateTime   @default(now())
  
  @@index([orderId])
  @@index([productId])
}

model Review {
  id        String     @id @default(cuid())
  
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  
  rating    Int        // 1-5
  title     String
  content   String?
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
}
